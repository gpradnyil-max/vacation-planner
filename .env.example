# GCP project hosting your BigQuery dataset
GCP_PROJECT_ID=your-project-id

# BigQuery dataset (created by /api/init or `npm run init-db`)
BQ_DATASET=vacation_planner
BQ_LOCATION=EU

# Local dev only — path to a service-account key JSON file with BigQuery permissions.
# Leave unset on Cloud Run; Application Default Credentials are picked up automatically.
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Default trip ID used when the UI loads (a trip with this ID is created on first init).
DEFAULT_TRIP_ID=my-vacation
DEFAULT_TRIP_NAME=Our 7-day vacation
DEFAULT_TRIP_START_DATE=2026-06-05
DEFAULT_TRIP_TRAVELLERS=2
